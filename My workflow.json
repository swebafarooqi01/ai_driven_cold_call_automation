      "parameters": {
        "jsCode": "const html = $json.body || $json.data || \"\";\nconst base = $json.normalized_url || \"\";\nconst baseUrl = new URL(base);\n\nconst matches = [\n  ...html.matchAll(/href=[\"']([^\"']+)[\"']/gi)\n];\n\nconst links = matches.map(m => m[1]).filter(link => link && link !== '#');\n\nconst contactKeywords = [\n  \"contact\",\n  \"contact-us\",\n  \"about\",\n  \"reach-us\",\n  \"get-in-touch\"\n];\n\nfunction normalizeLink(link) {\n  const trimmed = link.trim();\n  if (!trimmed) return null;\n  if (trimmed.startsWith('http://') || trimmed.startsWith('https://')) return trimmed;\n  if (trimmed.startsWith('//')) return `${baseUrl.protocol}${trimmed}`;\n  if (trimmed.startsWith('/')) return `${baseUrl.origin}${trimmed}`;\n  return `${baseUrl.origin}/${trimmed.replace(/^\/+/, '')}`;\n}\n\nconst contactLinks = links\n  .filter(link => {\n    const lower = link.toLowerCase();\n    return contactKeywords.some(keyword => lower.includes(keyword));\n  })\n  .map(normalizeLink)\n  .filter(Boolean);\n\nreturn [{\n  json: {\n    ...$json,\n    contactLinks: [...new Set(contactLinks)]\n  }\n}];"
      },
