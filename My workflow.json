      "parameters": {
        "jsCode": "const allItems = items || [];\nif (!allItems.length) return [];\n\nconst first = allItems[0].json || {};\nconst contactPages = [\n  ...new Set(allItems\n    .map(item => item.json?.contactLinks)\n    .filter(Boolean)\n  )\n];\n\nconst row = { ...first };\nfor (let i = 0; i < 5; i++) {\n  row[`contact ${i + 1}`] = contactPages[i] || '';\n}\nrow.contact_pages_count = contactPages.length;\n\nreturn [{ json: row }];"
      },
